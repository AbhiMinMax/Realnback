<UserControl x:Class="MemoryTrainer.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid Grid.Row="0" Margin="20,16,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="← Back" Style="{StaticResource SecondaryButton}" Command="{Binding GoBackCommand}"/>
            <TextBlock Grid.Column="1" Text="Settings" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="20,0,20,20" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Screenshots Folder -->
                <TextBlock Text="Screenshots Folder" Style="{StaticResource SectionHeader}" Margin="0,8,0,4"/>
                <TextBlock Text="Where screenshot files are saved. Must be writable. Changing this only affects new captures."
                           Style="{StaticResource Label}" TextWrapping="Wrap" Margin="0,0,0,8" MaxWidth="500" HorizontalAlignment="Left"/>
                <Grid Margin="0,0,0,4" MaxWidth="500" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding ScreenshotsFolder, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Browse…" Style="{StaticResource SecondaryButton}"
                            Margin="6,0,6,0" Command="{Binding BrowseScreenshotsFolderCommand}"/>
                    <Button Grid.Column="2" Content="Save" Command="{Binding SaveScreenshotsFolderCommand}"/>
                </Grid>

                <Separator Background="{StaticResource BorderBrush}" Margin="0,16,0,16" MaxWidth="500" HorizontalAlignment="Left"/>

                <!-- Default session name -->
                <TextBlock Text="Default Session Name Template" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
                <TextBlock Style="{StaticResource Label}" TextWrapping="Wrap" Margin="0,0,0,8" MaxWidth="500" HorizontalAlignment="Left"
                           Text="Used when the Session Name field is left blank on the Config screen."/>
                <Grid MaxWidth="500" HorizontalAlignment="Left" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding DefaultSessionNameTemplate, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Save" Margin="6,0,0,0"
                            Command="{Binding SaveSessionNameTemplateCommand}"/>
                </Grid>

                <Separator Background="{StaticResource BorderBrush}" Margin="0,16,0,16" MaxWidth="500" HorizontalAlignment="Left"/>

                <!-- Danger zone -->
                <TextBlock Text="Danger Zone" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                <Button Content="Delete All Captured Media" Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteAllScreenshotsCommand}"
                        HorizontalAlignment="Left" Margin="0,0,0,8"/>

                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}"
                           Visibility="{Binding StatusMessage, Converter={StaticResource EmptyStringToCollapsed}}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
