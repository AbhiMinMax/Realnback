<UserControl x:Class="MemoryTrainer.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MemoryTrainer.ViewModels">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid Grid.Row="0" Margin="20,16,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="MemoryTrainer" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="History" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                    Click="OnHistoryClick"/>
            <Button Grid.Column="2" Content="Settings" Style="{StaticResource SecondaryButton}"
                    Click="OnSettingsClick"/>
        </Grid>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" Margin="20,0,20,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Duration Cycles" Style="{StaticResource SectionHeader}" Margin="0,8,0,8"/>

                <ItemsControl ItemsSource="{Binding Cycles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SessionCycleConfigViewModel}">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <!-- Row 1: Duration, Window, Drift, Remove -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="Days:" Style="{StaticResource Label}" Margin="0,0,4,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding DurationDays, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Column="2" Text="Hours:" Style="{StaticResource Label}" Margin="8,0,4,0"/>
                                        <TextBox Grid.Column="3" Text="{Binding DurationHours, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Column="4" Text="Min:" Style="{StaticResource Label}" Margin="8,0,4,0"/>
                                        <TextBox Grid.Column="5" Text="{Binding DurationMinutes, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Column="6" Text="Window (min):" Style="{StaticResource Label}" Margin="8,0,4,0"/>
                                        <TextBox Grid.Column="7" Text="{Binding WaitingWindowMinutes, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Column="8" Text="Drift (min):" Style="{StaticResource Label}" Margin="8,0,4,0"/>
                                        <TextBox Grid.Column="9" Text="{Binding DriftMinutes, UpdateSourceTrigger=PropertyChanged}"/>

                                        <CheckBox Grid.Column="10" Content="Free Recall" IsChecked="{Binding FreeRecallEnabled}" Margin="12,0,8,0" VerticalAlignment="Center"/>
                                        <CheckBox Grid.Column="11" Content="Recognition" IsChecked="{Binding RecognitionEnabled}" VerticalAlignment="Center"/>

                                        <Button Grid.Column="13" Content="✕" Style="{StaticResource DangerButton}"
                                                Width="28" Height="28" Padding="0"
                                                Command="{Binding DataContext.RemoveCycleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>

                                    <!-- Validation error -->
                                    <TextBlock Text="{Binding ValidationError}" Foreground="{StaticResource ErrorBrush}"
                                               FontSize="11" Margin="0,4,0,0"
                                               Visibility="{Binding ValidationError, Converter={StaticResource NullToCollapsedConverter}}"/>

                                    <!-- Decoy offsets expander -->
                                    <StackPanel Margin="0,8,0,0">
                                        <Button Content="{Binding DecoyOffsetExpanded, Converter={StaticResource BoolToDecoyButtonText}}"
                                                Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"
                                                Padding="8,4" FontSize="11"
                                                Click="OnToggleDecoyExpand"/>

                                        <ItemsControl ItemsSource="{Binding DecoyOffsets}"
                                                      Visibility="{Binding DecoyOffsetExpanded, Converter={StaticResource BoolToVisibility}}"
                                                      Margin="0,6,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:DecoyOffsetViewModel}">
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                        <ComboBox SelectedItem="{Binding Sign}" Width="50" Margin="0,0,4,0">
                                                            <ComboBoxItem>+</ComboBoxItem>
                                                            <ComboBoxItem>-</ComboBoxItem>
                                                        </ComboBox>
                                                        <TextBox Text="{Binding OffsetMinutes, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                                                        <TextBlock Text="min" Style="{StaticResource Label}" Margin="6,0,8,0"/>
                                                        <Button Content="Remove" Style="{StaticResource SecondaryButton}" Padding="6,3" FontSize="11"
                                                                Command="{Binding DataContext.RemoveDecoyOffsetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Button Content="+ Add Offset" Style="{StaticResource SecondaryButton}"
                                                HorizontalAlignment="Left" Padding="8,4" FontSize="11"
                                                Margin="0,4,0,0"
                                                Command="{Binding AddDecoyOffsetCommand}"
                                                Visibility="{Binding DecoyOffsetExpanded, Converter={StaticResource BoolToVisibility}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="+ Add Duration Cycle" Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Left" Margin="0,4,0,16"
                        Command="{Binding AddCycleCommand}"/>

                <!-- Session name -->
                <TextBlock Text="Session Name (optional)" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding SessionName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" MaxWidth="400" HorizontalAlignment="Left"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Start button -->
        <Button Grid.Row="2" Content="Start Session"
                Command="{Binding StartSessionCommand}"
                IsEnabled="{Binding CanStart}"
                Margin="20,8,20,20" Height="40" FontSize="14" FontWeight="SemiBold"/>
    </Grid>
</UserControl>
