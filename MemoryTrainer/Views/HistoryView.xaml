<UserControl x:Class="MemoryTrainer.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MemoryTrainer.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid Grid.Row="0" Margin="20,16,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="← Back" Style="{StaticResource SecondaryButton}" Command="{Binding GoBackCommand}"/>
            <TextBlock Grid.Column="1" Text="History" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>
        </Grid>

        <!-- Filter bar -->
        <Grid Grid.Row="1" Margin="20,0,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Left: all filters -->
            <WrapPanel Grid.Column="0" Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <TextBlock Text="Date:" Style="{StaticResource Label}" Margin="0,0,6,0"
                               ToolTip="Filter results to a time range. Day = last 24 h, Week = last 7 days, etc."/>
                    <ComboBox SelectedValue="{Binding DatePreset}" SelectedValuePath="Content" Width="80">
                        <ComboBoxItem>Day</ComboBoxItem>
                        <ComboBoxItem IsSelected="True">Week</ComboBoxItem>
                        <ComboBoxItem>Month</ComboBoxItem>
                        <ComboBoxItem>Year</ComboBoxItem>
                        <ComboBoxItem>Custom</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                <!-- Custom date range pickers -->
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4"
                            Visibility="{Binding IsCustomDateRange, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="From:" Style="{StaticResource Label}" Margin="0,0,6,0"/>
                    <DatePicker SelectedDate="{Binding CustomFrom}" Width="120"/>
                    <TextBlock Text="To:" Style="{StaticResource Label}" Margin="8,0,6,0"/>
                    <DatePicker SelectedDate="{Binding CustomTo}" Width="120"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <TextBlock Text="Show Missed:" Style="{StaticResource Label}" Margin="0,0,6,0"
                               ToolTip="Missed cycles are ones where the app was closed before the screenshot could be taken."/>
                    <CheckBox IsChecked="{Binding ShowMissed}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <TextBlock Text="Mode:" Style="{StaticResource Label}" Margin="0,0,6,0"
                               ToolTip="Filter by recall mode."/>
                    <ComboBox SelectedValue="{Binding RecallModeFilter}" SelectedValuePath="Content" Width="110">
                        <ComboBoxItem IsSelected="True">All</ComboBoxItem>
                        <ComboBoxItem>Free Recall</ComboBoxItem>
                        <ComboBoxItem>Recognition</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <TextBlock Text="Capture:" Style="{StaticResource Label}" Margin="0,0,6,0"
                               ToolTip="Filter by capture type enabled for that cycle."/>
                    <ComboBox SelectedValue="{Binding CaptureTypeFilter}" SelectedValuePath="Content" Width="110">
                        <ComboBoxItem IsSelected="True">All</ComboBoxItem>
                        <ComboBoxItem>Screenshot</ComboBoxItem>
                        <ComboBoxItem>Audio</ComboBoxItem>
                        <ComboBoxItem>Camera</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Session:" Style="{StaticResource Label}" Margin="0,0,6,0"
                               ToolTip="Narrow results to a specific session."/>
                    <ComboBox ItemsSource="{Binding SessionFilterOptions}"
                              SelectedItem="{Binding SelectedSessionOption}"
                              DisplayMemberPath="DisplayName" Width="160"/>
                </StackPanel>
            </WrapPanel>
            <!-- Right: sort -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Top">
                <TextBlock Text="Sort:" Style="{StaticResource Label}" Margin="0,0,6,0"
                           ToolTip="Sort by date, duration, or recall result."/>
                <ComboBox SelectedValue="{Binding SortBy}" SelectedValuePath="Content" Width="90">
                    <ComboBoxItem IsSelected="True">Date</ComboBoxItem>
                    <ComboBoxItem>Duration</ComboBoxItem>
                    <ComboBoxItem>Result</ComboBoxItem>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Aggregation panel -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="20,0,20,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>
                <!-- Free recall + Recognition stats -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Free Recall" FontWeight="SemiBold" Margin="0,0,0,4"
                                   ToolTip="Written recall you self-evaluated as Correct, Partial, or Wrong."/>
                        <WrapPanel>
                            <TextBlock Text="{Binding TotalFreeRecall, StringFormat='Total: {0}'}" Margin="0,0,16,0" Style="{StaticResource Label}"
                                       ToolTip="Number of completed free recall evaluations in this period."/>
                            <TextBlock Text="{Binding CorrectFreeRecallPct, StringFormat='Correct: {0}'}" Foreground="{StaticResource SuccessBrush}" Margin="0,0,16,0"
                                       ToolTip="Right screen/app AND specific content recalled accurately."/>
                            <TextBlock Text="{Binding PartialFreeRecallPct, StringFormat='Partial: {0}'}" Foreground="{StaticResource WarningBrush}" Margin="0,0,16,0"
                                       ToolTip="Context right but content missed, or vice versa."/>
                            <TextBlock Text="{Binding WrongFreeRecallPct, StringFormat='Wrong: {0}'}" Foreground="{StaticResource ErrorBrush}" Margin="0,0,16,0"
                                       ToolTip="Neither screen nor content recalled correctly."/>
                            <TextBlock Text="{Binding FreeRecallStreak, StringFormat='Streak: {0}'}" Foreground="{StaticResource AccentBrush}"
                                       ToolTip="Current consecutive Correct count (most recent first). Resets on any non-Correct result."/>
                        </WrapPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Recognition" FontWeight="SemiBold" Margin="0,0,0,4"
                                   ToolTip="Screenshot selection task — you picked the correct screenshot from a set of options."/>
                        <WrapPanel>
                            <TextBlock Text="{Binding TotalRecognition, StringFormat='Total: {0}'}" Margin="0,0,16,0" Style="{StaticResource Label}"
                                       ToolTip="Number of completed recognition evaluations in this period."/>
                            <TextBlock Text="{Binding CorrectRecognitionPct, StringFormat='Correct: {0}'}" Foreground="{StaticResource SuccessBrush}" Margin="0,0,16,0"
                                       ToolTip="You selected the real screenshot."/>
                            <TextBlock Text="{Binding WrongRecognitionPct, StringFormat='Wrong: {0}'}" Foreground="{StaticResource ErrorBrush}" Margin="0,0,16,0"
                                       ToolTip="You selected a decoy."/>
                            <TextBlock Text="{Binding RecognitionStreak, StringFormat='Streak: {0}'}" Foreground="{StaticResource AccentBrush}"
                                       ToolTip="Current consecutive Correct count. Resets on any wrong selection."/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
                <!-- Audio + Camera stats -->
                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Audio Recall" FontWeight="SemiBold" Margin="0,0,0,4"
                                   ToolTip="Written recall of audio you heard, self-evaluated after listening back."/>
                        <WrapPanel>
                            <TextBlock Text="{Binding TotalAudio, StringFormat='Total: {0}'}" Margin="0,0,16,0" Style="{StaticResource Label}"/>
                            <TextBlock Text="{Binding CorrectAudioPct, StringFormat='Correct: {0}'}" Foreground="{StaticResource SuccessBrush}" Margin="0,0,16,0"/>
                            <TextBlock Text="{Binding PartialAudioPct, StringFormat='Partial: {0}'}" Foreground="{StaticResource WarningBrush}" Margin="0,0,16,0"/>
                            <TextBlock Text="{Binding WrongAudioPct, StringFormat='Wrong: {0}'}" Foreground="{StaticResource ErrorBrush}"/>
                        </WrapPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Camera Recall" FontWeight="SemiBold" Margin="0,0,0,4"
                                   ToolTip="Written recall of your appearance/surroundings, self-evaluated after viewing the webcam photo."/>
                        <WrapPanel>
                            <TextBlock Text="{Binding TotalCamera, StringFormat='Total: {0}'}" Margin="0,0,16,0" Style="{StaticResource Label}"/>
                            <TextBlock Text="{Binding CorrectCameraPct, StringFormat='Correct: {0}'}" Foreground="{StaticResource SuccessBrush}" Margin="0,0,16,0"/>
                            <TextBlock Text="{Binding PartialCameraPct, StringFormat='Partial: {0}'}" Foreground="{StaticResource WarningBrush}" Margin="0,0,16,0"/>
                            <TextBlock Text="{Binding WrongCameraPct, StringFormat='Wrong: {0}'}" Foreground="{StaticResource ErrorBrush}"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
                <!-- Chart -->
                <lvc:CartesianChart Grid.Row="2"
                                    Series="{Binding ChartSeries}"
                                    XAxes="{Binding ChartXAxes}"
                                    Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <!-- Detail table -->
        <Grid Grid.Row="3" Margin="20,0,20,20">
            <TextBlock Text="No results match the current filters."
                       Visibility="{Binding HasNoResults, Converter={StaticResource BoolToVisibility}}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Style="{StaticResource Label}"/>

            <ScrollViewer Visibility="{Binding HasNoResults, Converter={StaticResource InverseBoolToVisibility}}">
                <ItemsControl ItemsSource="{Binding Rows}"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:HistoryRowViewModel}">
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                    Padding="4,6">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ScreenshotTime}" Style="{StaticResource Label}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SessionName}" Style="{StaticResource Label}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DurationSlot}" Style="{StaticResource Label}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding CycleNumber, StringFormat='#{0}'}" Style="{StaticResource Label}"/>
                                        <TextBlock Grid.Column="4" Text="{Binding FreeRecallResult}"
                                                   Foreground="{Binding FreeRecallResult, Converter={StaticResource EvalResultToColor}}"/>
                                        <TextBlock Grid.Column="5" Text="{Binding RecognitionResult}"
                                                   Foreground="{Binding RecognitionResult, Converter={StaticResource EvalResultToColor}}"/>
                                        <TextBlock Grid.Column="6" Text="{Binding AudioResult}"
                                                   Foreground="{Binding AudioResult, Converter={StaticResource EvalResultToColor}}"/>
                                        <TextBlock Grid.Column="7" Text="{Binding CameraResult}"
                                                   Foreground="{Binding CameraResult, Converter={StaticResource EvalResultToColor}}"/>
                                        <TextBlock Grid.Column="8" Text="{Binding FreeRecallTextShort}"
                                                   Style="{StaticResource Label}" TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="9"
                                                Content="{Binding IsExpanded, Converter={StaticResource BoolToExpandArrow}}"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="4,2" FontSize="10"
                                                Visibility="{Binding FreeRecallTextFull, Converter={StaticResource EmptyStringToCollapsed}}"
                                                Click="OnExpandRow"/>
                                    </Grid>
                                    <!-- Expanded row -->
                                    <TextBlock Text="{Binding FreeRecallTextFull}"
                                               Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}"
                                               TextWrapping="Wrap" Margin="0,6,0,0"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
